# Copy to .env for a local install. Every value below is the default, so an
# empty .env — or no .env at all — is a working configuration.
#
# Anything already set in the environment wins over this file, so Docker's
# `environment:` block and `PORT=8080 npm start` both still take precedence.

# Standard Node environment flag: development or production.
NODE_ENV=development

# Where bananabook.db is written. Defaults to the working directory.
# Docker sets this to /app/data, which is where the volume is mounted.
DATA_DIR=

# The web port — the one you open in a browser.
PORT=3000

# The internal API port. Change it if something else on this machine already
# uses 3001. Independent of PORT: setting one never moves the other, and
# neither needs a rebuild.
API_PORT=3001

# Interface the API binds. Loopback by default, because browsers reach it
# through the app's own /api proxy rather than directly. Changing this exposes
# an unauthenticated API on that interface — see the threat model in README.md.
API_HOST=127.0.0.1
