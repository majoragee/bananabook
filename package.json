{
  "name": "bananabook",
  "version": "0.1.1",
  "private": true,
  "description": "A forward-looking checkbook: projects your account balance from recurring income and bills, and tells you the date it goes negative.",
  "license": "MIT",
  "author": "Craig",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/majoragee/bananabook.git"
  },
  "bugs": {
    "url": "https://github.com/majoragee/bananabook/issues"
  },
  "homepage": "https://github.com/majoragee/bananabook#readme",
  "engines": {
    "node": ">=20.9.0"
  },
  "keywords": [
    "personal-finance",
    "budgeting",
    "cash-flow",
    "forecasting",
    "self-hosted",
    "nextjs"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:next\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:next": "next dev",
    "build": "next build && npm run build:server",
    "build:server": "tsc -p tsconfig.server.json",
    "postbuild": "node -e \"require('fs').cpSync('.next/static','.next/standalone/.next/static',{recursive:true})\"",
    "start": "concurrently \"npm run start:server\" \"npm run start:next\"",
    "start:server": "node dist/index.js",
    "start:next": "node .next/standalone/server.js",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^12.5.0",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "next": "^16.0.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.21.0",
    "typeorm": "^0.3.27",
    "typescript": "^5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.1",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "vitest": "^4.1.10"
  }
}
