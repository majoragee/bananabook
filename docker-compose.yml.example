services:
  bananabook:
    # To use the prebuilt multi-arch image instead of building locally, comment
    # out the 'build' block below and uncomment this line:
    # image: ghcr.io/majoragee/bananabook:latest
    build:
      context: .
      dockerfile: Dockerfile
    container_name: bananabook
    ports:
      # Only the web port is published. The API is bound to loopback inside the
      # container and reached through the app's own /api proxy, so publishing it
      # would only expose a second, unauthenticated way in.
      # To serve on a different host port, change the left-hand number.
      - "3000:3000"
    environment:
      - NODE_ENV=production
      - DATA_DIR=/app/data
    volumes:
      - bananabook-data:/app/data
    restart: unless-stopped
    healthcheck:
      # Goes through the web server's proxy to the API, so a single probe covers
      # both processes. Hitting "/" would stay green with the API wedged.
      test: ["CMD", "wget", "--quiet", "--tries=1", "--spider", "http://localhost:3000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

volumes:
  bananabook-data:
    driver: local
